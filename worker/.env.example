# Copy to worker/.env on the worker box (Rodney). Gitignored.

# Public Supabase URL — the SAME value whether the worker is on the LAN today or
# a cloud box later. That constancy is the point: moving the worker never
# changes this file. (Reaching Patrick's Kong directly would be faster on the
# LAN but would have to change the day the box moves — don't.)
SUPABASE_URL=https://mm-supa.compunist.nl

# The worker's key. Two choices:
#   • worker_external JWT  — scoped (claim + update submissions + storage), the
#     production choice. Mint with scripts/mint_jwt.py:
#         SUPABASE_JWT_SECRET='<the stack JWT_SECRET>' \
#           python ../scripts/mint_jwt.py --role worker_external --years 10
#   • service_role key     — god mode, bypasses everything. Fine for first
#     bring-up; if storage ops misbehave under worker_external, this rules the
#     role in or out as the cause.
# Whichever you use, this key is the entire trust boundary — guard it, and plan
# to rotate it (mint a new long-lived one; the old stays valid until expiry).
SUPABASE_KEY=

SUBMISSIONS_BUCKET=submissions
RESULTS_BUCKET=results

# Optional. WORKER_ID defaults to <hostname>:<pid>.
# WORKER_ID=
POLL_SECONDS=30
HEARTBEAT_SECONDS=60
