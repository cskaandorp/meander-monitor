# Copy to .env.local and fill in. Gitignored, so deploys leave it in place.
#
# Both are NEXT_PUBLIC_*, which means they are baked into the client bundle at
# BUILD time — not read at runtime. This file must exist before `npm run build`,
# and changing either value requires a rebuild, not just a restart.
#
# On Patrick this lives at /var/www/meander-monitor/.env.local. The systemd unit
# also injects it via EnvironmentFile — the standalone server does not auto-load
# .env.local the way `next dev` does.
#
# The anon key is public by design (it ships in the browser bundle). It is a JWT
# signed with the Supabase stack's JWT_SECRET, carrying role=anon; RLS is what
# actually protects the data. Never put SERVICE_ROLE_KEY here — it bypasses RLS
# and would be served to every visitor.

NEXT_PUBLIC_SUPABASE_URL=https://mm-supa.compunist.nl
NEXT_PUBLIC_SUPABASE_ANON_KEY=
